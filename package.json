{
  "name": "universal-app-bridge",
  "version": "0.6.0",
  "description": "Framework-level desktop app control for AI agents. Hook into Chrome, Electron, Qt, GTK, WPF, Flutter, Java, and Office apps with a unified API.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "uab": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "data/chrome-extension",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "desktop-automation",
    "ui-automation",
    "accessibility",
    "electron",
    "cdp",
    "chrome-devtools-protocol",
    "qt",
    "gtk",
    "wpf",
    "flutter",
    "java",
    "office",
    "ai-agent",
    "app-control",
    "framework-hook",
    "uia",
    "windows-automation",
    "chrome-extension",
    "browser-automation"
  ],
  "dependencies": {
    "ws": "^8.16.0"
  },
  "author": "myles1663",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/myles1663/UAB"
  },
  "bugs": {
    "url": "https://github.com/myles1663/UAB/issues"
  },
  "homepage": "https://github.com/myles1663/UAB#readme",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
